{
  "name": "exile-build-poe",
  "productName": "Exile Build PoE",
  "version": "1.0.10",
  "private": true,
  "author": "ElyelxD",
  "description": "Open-source Windows desktop overlay for Path of Exile build progression.",
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/ElyelxD/Exile-Build-PoE",
  "bugs": "https://github.com/ElyelxD/Exile-Build-PoE/issues",
  "keywords": [
    "path-of-exile",
    "poe",
    "pob",
    "overlay",
    "build-guide",
    "electron",
    "desktop"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist-electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElyelxD/Exile-Build-PoE.git"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\" \"npm:dev:app\"",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:app": "wait-on tcp:5173 file:dist-electron/main.js && electron .",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "build:icon": "python3 scripts/generate_icon.py",
    "mine:poe-assets": "python3 scripts/mine_poe_assets.py",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "pack:win": "npm run build && electron-builder --publish never --win --dir",
    "dist:win": "npm run build && electron-builder --publish never --win nsis --x64",
    "dist:win:web": "npm run build && electron-builder --publish never --win nsis-web --x64",
    "dist:win:portable": "npm run build && electron-builder --publish never --win portable --x64"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.exilebuildpoe.desktop",
    "productName": "Exile Build PoE",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "tray-icon.ico"
      },
      {
        "from": "scripts/mine_poe_assets.py",
        "to": "scripts/mine_poe_assets.py"
      }
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "ElyelxD",
        "repo": "Exile-Build-PoE",
        "releaseType": "release"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "executableName": "Exile Build PoE",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Exile Build PoE",
      "uninstallDisplayName": "Exile Build PoE"
    },
    "nsisWeb": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Exile Build PoE",
      "uninstallDisplayName": "Exile Build PoE",
      "artifactName": "Exile-Build-PoE-Web-Installer.${ext}",
      "appPackageUrl": "https://github.com/ElyelxD/Exile-Build-PoE/releases/download/windows-installer-latest"
    }
  }
}
